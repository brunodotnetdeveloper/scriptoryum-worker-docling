# Configurações do banco de dados PostgreSQL
DB_HOST=localhost
DB_NAME=scriptoryum
DB_USER=postgres
DB_PASSWORD=password
DB_PORT=5432

# Configurações do Redis
REDIS_CONNECTION_STRING=redis://localhost:6379
REDIS_QUEUE=document_processing_queue

# Configurações do Cloudflare R2
CLOUDFLARE_SERVICE_URL=https://your-account-id.r2.cloudflarestorage.com
CLOUDFLARE_ACCESS_KEY=your_access_key
CLOUDFLARE_SECRET_KEY=your_secret_key
CLOUDFLARE_BUCKET_NAME=your_bucket_name

# Configuração do Tesseract OCR (opcional)
# No Windows: TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
# No Linux/Mac: deixe vazio se tesseract estiver no PATH
# No Docker: NÃO é necessário configurar (deixe vazio)
TESSERACT_PATH=